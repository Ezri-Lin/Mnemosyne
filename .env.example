# Mnemosyne Configuration
# Copy this file to .env and fill in your values

# ============ Paths ============
# Where Mnemosyne stores uploaded books, generated HTML, covers, DB
MNEMO_DATA_DIR=/Users/ezri/code/Mnemosyne/data

# ============ Database ============
# Default: SQLite in MNEMO_DATA_DIR/mnemosyne.db
# Override for PostgreSQL/MySQL:
#   postgresql://user:pass@localhost:5432/mnemosyne
#   mysql+pymysql://user:pass@localhost:3306/mnemosyne
DATABASE_URL=sqlite:////Users/ezri/code/Mnemosyne/data/mnemosyne.db

# ============ Language ============
# Default language for: UI text, generated content, log messages.
# Supported: en, zh, ja, es, fr, de
MNEMO_LANG=en

# ============ Vault (Golden-House) ============
# Path to your local Obsidian vault
VAULT_DIR=/Users/ezri/Library/Mobile Documents/iCloud~md~obsidian/Documents/Golden House
# GitHub repo for vault (read-only from server)
VAULT_REPO=https://github.com/Ezri-Lin/Golden-House.git

# ============ AI / Hermes ============
# Your Anthropic API key (optional; enables AI analysis)
ANTHROPIC_API_KEY=

# ============ External APIs ============
# Allow searching Anna's Archive (copyright gray zone; default OFF)
ANNA_ARCHIVE_ENABLED=false
# Use Open Library for metadata (default ON)
OPENLIBRARY_ENABLED=true

# ============ Sync ============
# How often to pull latest from vault (minutes)
VAULT_SYNC_INTERVAL_MIN=30

# ============ Server ============
# Port to run Flask on
MNEMO_PORT=5000

# Flask debug mode (NEVER true in production)
FLASK_ENV=production
